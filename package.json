{
  "name": "effect-react-poc",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter ./examples/* dev",
    "_lint:eslint": "eslint .",
    "_lint:prettier": "prettier . --check",
    "lint": "eslint . && prettier . --check",
    "lint-fix": "eslint . --fix && prettier . --write",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:run": "vitest run",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc -b"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@luma-dev/eslint-plugin-luma-ts": "^1.3.0",
    "@typescript-eslint/eslint-plugin": "^8.34.1",
    "@typescript-eslint/parser": "^8.34.1",
    "@vitest/coverage-v8": "^3.1.4",
    "eslint": "^9.28.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.1",
    "vitest": "^3.1.4"
  },
  "packageManager": "pnpm@10.30.3",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
